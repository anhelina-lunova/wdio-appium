{
    "compilerOptions": {
        "types": [
            "node",
            "@wdio/globals/types",
            "@wdio/mocha-framework",
            "expect-webdriverio",
            "@wdio/appium-service"
        ],
        "paths": {
            "#test/*": ["./test/*"],
            "#pages/*": ["./test/page-objects/pages/*"],
            "#forms/*": ["./test/page-objects/forms/*"]
        }
    },
    "include": ["test/**/*"],
    "exclude": ["allure-report", "allure-results", "apps", "node_modules"]
}
