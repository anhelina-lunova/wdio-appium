{
    "compilerOptions": {
        "ignoreDeprecations": "6.0",
        "types": [
            "node",
            "@wdio/globals/types",
            "@wdio/mocha-framework",
            "expect-webdriverio",
            "@wdio/appium-service"
        ],
        "baseUrl": ".",
        "paths": {
            "#test/*": ["./test/*"],
            "#screens-android/*": ["test/android/page-objects/screens/*"],
            "#forms-android/*": ["test/android/page-objects/forms/*"],
            "#screens-ios/*": ["test/ios/page-objects/screens/*"],
            "#forms-ios/*": ["test/ios/page-objects/forms/*"]
        }
    },
    "include": ["test/**/*", "config/*"],
    "exclude": ["allure-report", "allure-results", "apps", "node_modules"]
}
