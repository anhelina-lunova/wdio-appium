{
    "name": "wdio-appium",
    "type": "module",
    "imports": {
        "#test/*": "./test/*",
        "#pages/*": "./test/page-objects/pages/*",
        "#forms/*": "./test/page-objects/forms/*"
    },
    "devDependencies": {
        "@wdio/allure-reporter": "^9.27.1",
        "@wdio/appium-service": "^9.27.1",
        "@wdio/cli": "^9.27.1",
        "@wdio/local-runner": "^9.27.1",
        "@wdio/mocha-framework": "^9.27.1",
        "@wdio/spec-reporter": "^9.27.1",
        "allure-commandline": "^2.38.1",
        "appium": "^3.3.1",
        "appium-uiautomator2-driver": "^7.2.2",
        "appium-xcuitest-driver": "^11.2.4",
        "dotenv": "^17.4.2"
    },
    "scripts": {
        "vd-list": "emulator -list-avds",
        "start-vd-headed": "emulator -avd Samsung_Galaxy_S10",
        "start-vd-headless": "emulator -avd Samsung_Galaxy_S10 -no-window -no-audio -no-boot-anim -accel on -gpu swiftshader_indirect",
        "started-vds": "adb devices",
        "allure-report": "npx allure generate ./allure-results --clean && npx allure open",
        "and-search": "npx wdio run config/android-wdio.conf.js --spec ./test/android/specs/search.e2e.js",
        "and-actions": "npx wdio run config/android-wdio.conf.js --spec ./test/android/specs/actions.e2e.js",
        "and-native-actions": "npx wdio run config/android-wdio.conf.js --spec ./test/android/specs/nativeActions.e2e.js",
        "and-sign-in": "npx wdio run config/android-wdio.conf.js --spec ./test/android/specs/signIn.e2e.js",
        "and-homework-1": "npx wdio run config/android-wdio.conf.js --spec ./test/android/specs/homeworks/hw1Search.e2e.js",
        "and-homework-2": "npx wdio run config/android-wdio.conf.js --spec ./test/android/specs/homeworks/hw2Actions.e2e.js",
        "and-homework-3": "npx wdio run config/android-wdio.conf.js --spec ./test/android/specs/homeworks/hw3NativeActions.e2e.js",
        "ios-search": "npx wdio run config/ios-wdio.conf.js --spec ./test/ios/specs/search.e2e.js",
        "ios-actions": "npx wdio run config/ios-wdio.conf.js --spec ./test/ios/specs/actions.e2e.js",
        "ios-native-actions": "npx wdio run config/ios-wdio.conf.js --spec ./test/ios/specs/nativeActions.e2e.js",
        "ios-sign-in": "npx wdio run config/ios-wdio.conf.js --spec ./test/ios/specs/signIn.e2e.js",
        "and-web-test": "npx wdio run config/android-browser-wdio.conf.js --spec ./test/mobile-browser/specs/test.e2e.js"
    }
}
